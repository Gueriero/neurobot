# Wildberries API keys (one per IP)
WB_API_KEY_US=your_token_here
WB_API_KEY_KUZ=your_token_here
WB_API_KEY_NOV=your_token_here

# Google Sheets
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Database
# Local: DB_HOST=localhost
# Docker: DB_HOST=db (set automatically in docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wb_tracker
DB_USER=cardgit
DB_PASSWORD=your_password_here
